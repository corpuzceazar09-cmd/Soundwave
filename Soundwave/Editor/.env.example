# Supabase — data queries (podcasts, episodes, highlights)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# Editor auth (CHANGE these in production!)
EDITOR_EMAIL=editor@example.com
EDITOR_PASSWORD=change-this-password
JWT_SECRET=change-this-jwt-secret

# MongoDB (optional — audit logging)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/soundwave-editor?retryWrites=true&w=majority

# Server
PORT=8080
