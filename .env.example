# Supabase Configuration (Admin)
# The URL to your Supabase project
EXPO_PUBLIC_SUPABASE_URL=https://placeholder.supabase.co
# The Anon Key
EXPO_PUBLIC_SUPABASE_ANON_KEY=placeholder-key

# MongoDB Configuration (Editor)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/soundwave_editor?retryWrites=true&w=majority

# Firebase Configuration (Public Users)
EXPO_PUBLIC_FIREBASE_API_KEY=placeholder-api-key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=placeholder-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=placeholder-project
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=placeholder-project.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=placeholder-sender-id
EXPO_PUBLIC_FIREBASE_APP_ID=placeholder-app-id
